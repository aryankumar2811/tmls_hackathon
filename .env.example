# ─── LLMs ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ORCHESTRATOR_MODEL=claude-sonnet-4-6     # supervisor + Correlation agent
AGENT_MODEL=claude-haiku-4-5             # fast specialist agents

# ─── Embeddings (pick one) ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...                    # text-embedding-3-small
VOYAGE_API_KEY=                          # voyage-3 (alternative)
EMBEDDING_PROVIDER=openai                # openai | voyage

# ─── Tracing ─────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=ovenmind

# ─── RAG ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ─── Alerts ──────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── Cost guardrails (DO NOT REMOVE — a runaway supervisor can burn credits) ─
MAX_SUPERVISOR_TURNS=8
MAX_TOKENS_PER_AGENT=4000

# ─── Demo replay ─────────────────────────────────────────────────────────
REPLAY_SPEED=3.0        # 1.0 = real-time; 3.0 compresses the 60s scenario to ~20s
USE_RUN_CACHE=true      # cache the first real agent run per scenario; replay after

# ─── Frontend ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:8000
